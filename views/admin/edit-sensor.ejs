<%- include('../includes/head.ejs') %>
    <link rel="stylesheet" href="/css/forms.css">
    <link rel="stylesheet" href="/css/product.css">
</head>

<body>
   <%- include('../includes/navbar.ejs') %>

    <main>
        <% if(errorMessage) { %>
            <div class="user-message user-message--error"><%= errorMessage %></div>
        <% } %>
        <form class="product-form" action="/edit-sensor" method="POST">
            <div class="form-control">
                <label for="title">Title</label>
                <input type="text" name="title" id="title" value="<%= sensor.title %>">
            </div>
            <div class="form-control">
                <label for="imageUrl">Image URL</label>
                <input type="text" name="imageUrl" id="imageUrl" value="<%= sensor.imageUrl %>">
            </div>
            <!-- <div class="form-control">
                <label for="image">Image</label>
                <input type="file" name="image" id="image">
            </div> -->
            <!-- <div class="form-control">
                <label for="price">Price</label>
                <input type="number" name="price" id="price" step="0.01" value="<%= sensor.price %>">
            </div> -->
            <div class="form-control">
                <label for="description">Description</label>
                <textarea name="description" id="description" rows="5"><%= sensor.description %></textarea>
            </div>
            <input type="hidden" value="<%= sensor._id %>" name="sensorId">
            <button class="btn" type="submit">Update Sensor</button>
        </form>
    </main>
</body>